function LoadBoss(v)
    if not v or v.ClassName ~= 'Model' then return end
    local CastleCFrame = CFrame.new(-5543.5327148438, 313.80062866211, -2964.2585449219)
    local Root = v.PrimaryPart or v:WaitForChild('HumanoidRootPart', 3)
    local Hum = v:FindFirstChild('Humanoid')
    if not Hum or not Root then return end
    local IsElite = table.find(Elites, RemoveLevelTitle(v.Name))
    local RealName = Hum.DisplayName
    local cleanName = RemoveLevelTitle(v.Name)
    local IsBoss = (RealName and RealName:find('Boss') and not RealName:find("Tormented", 1, true)) or v.Name == 'Core'
    task.spawn(function()
        if skidymf(v) and IsBoss and not IsElite and not Bosses[v.Name] then
            print('Added Boss ' .. RealName)
            Bosses[v.Name] = v
            if not v:HasTag("PostedAPI") then
                local sent  = false
                if v.Name == "Dough King" then DummyFunc(EmptyData["Dough King"], "Dough King"); sent = true
                elseif cleanName == "Soul Reaper" then DummyFunc(EmptyData["Soul Reaper"], "Soul Reaper"); sent = true
                elseif cleanName == "Darkbeard" then DummyFunc(EmptyData["Darkbeard"], "Darkbeard"); sent = true
                elseif cleanName == "Cake Queen" then DummyFunc(EmptyData["Cake Queen"], "Cake Queen"); sent = true
                elseif cleanName == "rip_indra True Form" then DummyFunc(EmptyData["rip_indra"], "rip_indra"); sent = true
                end
                if sent then
                    print(cleanName)
                    v:AddTag("PostedAPI") 
                end
            end
        end
    end)
    task.spawn(function()
        if World3 and skidymf(v) and GetDistance(v.PrimaryPart, CastleCFrame) <= 1500 and (RemoveLevelTitle(v.Name) ~= 'rip_indra True Form' and not v.Name:find('Friend') and not v.Name:find("Player")) then
            v:AddTag('PirateMob')
            if not getgenv().PirateRaidTick then getgenv().PirateRaidTick = tick() end
            if not RaidCastlePosted then
                RaidCastlePosted = true
                DummyFunc(EmptyData["Raid Castle"], "Pirate Raid")
            end
        end
    end)
    if IsElite and skidymf(v) then
        print("Found elite:", tostring(v.Name))
        _G.CurrentElite = v
        if not v:HasTag("PostedAPI") then
            DummyFunc(EmptyData["Elite Hunter"], "Elite - " .. cleanName)
            v:AddTag("PostedAPI")
        end
    end
    if IsBoss or IsElite then
        if Hum and Hum:IsA("Humanoid") then
            local connection2
            connection2 = Hum:GetPropertyChangedSignal("Health"):Connect(function()
                if Hum.Health <= 0 then
                    if (IsElite or Bosses[v.Name]) then
                        if v:HasTag('PostedAPI') then
                            v:RemoveTag('PostedAPI')
                        end
                        print('Removed boss:', v.Name)
                        if IsElite then
                            _G.CurrentElite = nil
                        end
                        if Bosses[v.Name] then
                            Bosses[v.Name] = nil
                        end
                    end
                    connection2:Disconnect()
                end
            end)
        end
    end
end

