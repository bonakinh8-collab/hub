function SmartResetStat(PrimaryPoint)
    local PlayerData = game.Players.LocalPlayer.Data
    local Stats = PlayerData.Stats
    local UnspentPoints = PlayerData.Points.Value
    if UnspentPoints > 0 then
        game.ReplicatedStorage.Remotes.CommF_:InvokeServer("AddPoint", "Melee", UnspentPoints)
        wait(0.1)
        UnspentPoints = PlayerData.Points.Value
        if UnspentPoints > 0 then
            game.ReplicatedStorage.Remotes.CommF_:InvokeServer("AddPoint", "Defense", UnspentPoints)
            wait(0.1)
        end
        UnspentPoints = PlayerData.Points.Value
        if UnspentPoints > 0 then
            game.ReplicatedStorage.Remotes.CommF_:InvokeServer("AddPoint", PrimaryPoint, UnspentPoints)
            wait(0.1)
        end
    end
    if PlayerData.Points.Value < 100 then
        local isThotStat = (Stats[PrimaryPoint].Level.Value < 2000) or 
                           (Stats["Melee"].Level.Value < 2000) or 
                           (Stats["Defense"].Level.Value < 2000)
                           
        if isThotStat then
            print("akiki", "Phát hiện cộng sai Stat, tiến hành Reset...")
            
            if ScriptStorage.PlayerData.StatRefunds > 0 then
                game.ReplicatedStorage.Remotes.CommF_:InvokeServer("redeemRefundPoints", "Refund Points")
                print("akiki", 'Đã dùng Stat Refund Code!')
            elseif ScriptStorage.PlayerData.Fragments > 2500 then
                game.ReplicatedStorage.Remotes.CommF_:InvokeServer("BlackbeardReward", "Refund", "1")
                game.ReplicatedStorage.Remotes.CommF_:InvokeServer("BlackbeardReward", "Refund", "2")
                print("akiki", 'Đã dùng 2500 F để tẩy điểm!')
            else
                warn("Không đủ điều kiện để tẩy điểm (Hết Code & Thiếu F)")
                return false
            end
            
            wait(1.5)
           game.ReplicatedStorage.Remotes.CommF_:InvokeServer("AddPoint", "Melee", 9999)
            wait(0.1)
            game.ReplicatedStorage.Remotes.CommF_:InvokeServer("AddPoint", "Defense", 9999)
            wait(0.1)
            game.ReplicatedStorage.Remotes.CommF_:InvokeServer("AddPoint", PrimaryPoint, 9999)
        end
    end
    return true
end

