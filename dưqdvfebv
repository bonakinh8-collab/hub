        MobInstance.Name == 'Core' or table.find(Elites, MobInstance.Name)
    getgenv().CurrentFarmTaskDoing = "Killing " .. MobInstance.Name
    if table.find(DoughBoss, MobInstance.Name) and GetDistance(MobInstance.HumanoidRootPart.CFrame) > 1000 then
        -- Sử dụng bypass TP giống trong farm_kata_api.lua nhưng đúng thứ tự
        local GATE_POSITION = Vector3.new(-2152.15, 120, -12398.39)
        for _, part in Character:GetDescendants() do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
        -- Đầu tiên TP1 đến ngay trước cổng Mirror World
        TP1(CFrame.new(GATE_POSITION))
        local timeout = 20
        local elapsed = 0
        while elapsed < timeout do
            wait(0.5)
            elapsed = elapsed + 0.5
            if GetDistance(GATE_POSITION) < 50 then break end
        end
        -- Sau khi đã đến gần cổng mới gọi requestEntrance để tránh bị kick
        pcall(function()
            CommF:InvokeServer("requestEntrance", GATE_POSITION)
        end)
        wait(2)
    end
    if MobInstance:HasTag('secondmob') then MobInstance:RemoveTag('secondmob') end
    MobInstance:AddTag('realmob')
    local mobhumanoid = MobInstance.Humanoid
    local Count, Count2, Debounce = 0, 0, os.time()
    local SpinIncrement = 0
    repeat
        wait()
        local success, err = pcall(function()
            if not IsPlayerAlive() then return end
            if not skidymf(MobInstance) then return end
            if not MobInstance:FindFirstChild("HumanoidRootPart") then return end
            if GetDistance(MobInstance.HumanoidRootPart.CFrame) <= 200 then
                Character.HumanoidRootPart.CFrame = CalDirection(MobInstance.HumanoidRootPart.CFrame) *
                    CFrame.new(0, 15, 0)
            else
                TP1(CalDirection(MobInstance.HumanoidRootPart.CFrame) * CFrame.new(0, 30, 0))
            end
            if GetDistance(MobInstance.HumanoidRootPart.CFrame) < 150 then
                if Count >= 3 and mobhumanoid.Health - mobhumanoid.MaxHealth == 0 then
                    Count = 0
                    AddIgnoreTag(MobInstance)
                    local oldpos = MobInstance:GetAttribute("OldPosition")
                    if oldpos then
                        Notify('tp back')
                        MobInstance:SetPrimaryPartCFrame(CFrame.new(oldpos))
                        MobInstance.HumanoidRootPart.CanCollide = false
                        MobInstance:SetAttribute("Count", (MobInstance:GetAttribute("Count") or 0) + 1)
                        wait()
                        return
                    end
                end
                if test and
                    math.floor(MobInstance.Humanoid.Health / MobInstance.Humanoid.MaxHealth * 100) < 30
                    and not game.Players.LocalPlayer:GetAttribute("IslandRaiding") then
                        EquipWeapon(game:GetService("Players").LocalPlayer.Data.DevilFruit.Value)
                        LockAimPositionTo(MobInstance.HumanoidRootPart.Position)
                        local moves = {"Z", "X", "C", "V"}
                        local move = moves[math.random(1, #moves)]
                        SendKey(move, .31)
                    else
                    local TargetWeapon = getgenv().WeaponType or "Melee"
                    local Weapon = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                    if not Weapon or Weapon.ToolTip ~= TargetWeapon then
                        EquipWeapon() 
                        Notify('equip wp')
                    end

            end
                if GetDistance(MobInstance.HumanoidRootPart.CFrame) < 50 then
                    if not IsBoss and getgenv().CurrentFarmTask ~= "Farm Pirate Raid" and not MobInstance:HasTag('Ignore') then
                        if not brought and not game.Players.LocalPlayer:GetAttribute("IslandRaiding") then
                            brought = BringMob(MobInstance,MobInstance.HumanoidRootPart.CFrame)
                        elseif game.Players.LocalPlayer:GetAttribute("IslandRaiding") then
                            BringinRaid(MobInstance, MobInstance.HumanoidRootPart.CFrame)
                        end
                    end
                end
                FastAttack:attack()
                if os.time() ~= Debounce then
                    Debounce = os.time()
                    Count = Count + 1
                    Count2 = Count2 + 1
                end
            end
        end)
        if not success then
            print('kill function error ' .. tostring(err))
        end
    until not skidymf(MobInstance) or not IsPlayerAlive()
    if not skidymf(MobInstance) then
        MobInstance:Destroy()
    end
end

