               (currentFruit == "" or not table.find(NAH.TableFruit.ListFruit, currentFruit)) and 
               table.find(NAH.TableFruit.ListFruit, originalName) 
            then
                while not LocalPlayer.Character:FindFirstChild(v.Name) and wait() do
                    local fruitInBackpack = LocalPlayer.Backpack:FindFirstChild(v.Name)
                    if fruitInBackpack then
                        LocalPlayer.Character.Humanoid:EquipTool(fruitInBackpack)
                    end
                end

                local equippedFruit = LocalPlayer.Character:FindFirstChild(v.Name)
                if equippedFruit then
                    local eatRemote = equippedFruit:WaitForChild("EatRemote", 3)
