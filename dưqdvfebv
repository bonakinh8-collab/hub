function GetNearMob(MobName, path)
    path = path or game.workspace.Enemies
    if not path:FindFirstChild(MobName) then return false end
    local Distance, Mob = math.huge, false
    for _, enemy in pairs(path:GetChildren()) do
        if enemy.Name == MobName and skidymf(enemy) and GetDistance(enemy.HumanoidRootPart.CFrame) < Distance then
            Distance = GetDistance(enemy.HumanoidRootPart)
            Mob = enemy
        end
    end
    return Mob
end

function GetNearMobinList(List, path)
    path = path or game.workspace.Enemies
    local Distance, Mob = math.huge, nil
    for _, enemy in pairs(path:GetChildren()) do
        if table.find(List, enemy.Name) and skidymf(enemy) and GetDistance(enemy.HumanoidRootPart) < Distance then
            Distance = GetDistance(enemy.HumanoidRootPart)
            Mob = enemy
        end
    end
    return Mob
end

function CheckMob(mobormoblist, rep)
    if typeof(mobormoblist) == 'table' then
        Mob = GetNearMobinList(mobormoblist)
        if Mob then return Mob end
        if rep then
            return GetNearMobinList(mobormoblist, ReplicatedStorage)
        end
    else
        if game.workspace.Enemies:FindFirstChild(mobormoblist) then
            return GetNearMob(mobormoblist)
        end
        if rep then
            if ReplicatedStorage:FindFirstChild(mobormoblist) then
                return GetNearMob(mobormoblist, ReplicatedStorage)
            end
        end
    end
    return nil
end



function TeleportSpawnMob(MobName)
    local Returner = {}
    
    local function getSpawn(name)
        if DynamicMobSpawns and DynamicMobSpawns[name] then
            return DynamicMobSpawns[name]
        end
        return nil
    end

    if type(MobName) == "table" then
        for _, name in pairs(MobName) do
            local pos = getSpawn(name)
            if pos then
                if type(pos) == "table" then
                    for _, p in pairs(pos) do table.insert(Returner, p) end
                else
                    table.insert(Returner, pos)
                end
            end
        end
    else
        local pos = getSpawn(MobName)
        if pos then
            if type(pos) == "table" then
                for _, p in pairs(pos) do table.insert(Returner, p) end
            else
                table.insert(Returner, pos)
            end
        end
    end
    
    return Returner
end

